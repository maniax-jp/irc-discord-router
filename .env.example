# IRC Server Configuration
IRC_SERVER="irc.example.com"
IRC_PORT=6667
IRC_NICK="BOT_DISCORD"
IRC_USER="bot_user"

# Discord Bot Configuration
DISCORD_BOT_TOKEN="your_discord_bot_token_here"

# Channel Pairs Configuration
# Format: "irc_channel:discord_channel_id,irc_channel2:discord_channel_id2"
# Example: "#test:123456789012345678,#general:987654321098765432"
CHANNEL_PAIRS="#test:123456789012345678"
